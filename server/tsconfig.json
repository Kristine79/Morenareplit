{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "express", "express-serve-static-core"],
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "composite": false,
    "declaration": false,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "**/*.ts"
  ]
}
