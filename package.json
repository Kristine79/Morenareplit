{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:api": "pnpm --filter @workspace/api-zod run build 2>/dev/null; echo 'API routes use ts-node directly'",
    "build:admin": "pnpm --filter @workspace/admin-panel run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:api": "tsx watch api/dev.ts",
    "start": "node --enable-source-maps api/index.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "vercel:build": "prisma generate && pnpm -r --filter @workspace/api-zod run build"
  },
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@replit/connectors-sdk": "^0.4.1",
    "@vercel/node": "^5.1.14",
    "axios": "^1.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "grammy": "^1.36.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@grammyjs/types": "^3.19.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "catalog:",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prisma": "^6.9.0",
    "tsx": "catalog:",
    "typescript": "~5.9.3"
  }
}
