{
  "framework": null,
  "buildCommand": "pnpm prisma generate && pnpm --filter @workspace/admin-panel run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/expiry",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/admin(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/auth(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/platega(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/healthz",
      "destination": "/api/index"
    },
    {
      "source": "/api/webhook(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/cron(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
