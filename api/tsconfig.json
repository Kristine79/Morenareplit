{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "express", "express-serve-static-core"],
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "skipLibCheck": true
  },
"include": [
    "*.d.ts",
    "index.ts",
    "app.ts",
    "lib/**/*.ts",
    "middleware/**/*.ts",
    "routes/**/*.ts"
]
}
